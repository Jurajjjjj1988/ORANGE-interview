{
  "name": "orange-test-suite",
  "version": "1.0.0",
  "description": "API test suite for orange.sk — Playwright API tests + Pact contract tests + Postman collection",
  "scripts": {
    "test": "playwright test",
    "test:pact": "jest --config api-tests/pact-tests/jest.config.ts",
    "test:postman": "newman run api-tests/postman/collections/orange-sk-eshop.postman_collection.json -e api-tests/postman/environments/production.postman_environment.json",
    "test:all": "npm run test:pact && npm test && npm run test:postman"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@pact-foundation/pact": "^13.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "zod": "^3.23.0",
    "typescript": "^5.4.0"
  }
}
