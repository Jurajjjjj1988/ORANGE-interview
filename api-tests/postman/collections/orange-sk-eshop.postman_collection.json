          ],
          "path": [
            "api",
            "browser",
            "service_status",
            "NEEXISTUJUCI-SERVICE-999",
            "EN"
          ]
        },
        "description": "NEGATIVE | Neplatny service ID. KNOWN DEFECT CB24-001."
      },
