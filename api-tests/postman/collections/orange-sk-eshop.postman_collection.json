    {
      "name": "[FUNC+DATA] Callback24 - obsah a brand",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var body = pm.response.json();",
              "var expectedCompany = pm.environment.get('expected_company_name');",
              "var expectedColor = pm.environment.get('brand_color');",
              "pm.test('F1: status je boolean', function(){ pm.expect(body.status).to.be.a('boolean'); });",
              "pm.test('F2: mode je ONLINE alebo OFFLINE', function(){ pm.expect(['ONLINE','OFFLINE']).to.include(body.mode); });",
              "pm.test('F3: company_name je ' + expectedCompany, function(){ pm.expect(body.company_name).to.eql(expectedCompany); });",
              "pm.test('D1: widget_color je ' + expectedColor, function(){ if(body.widget_color){ pm.expect(body.widget_color.trim().toUpperCase()).to.eql(expectedColor.toUpperCase()); } });",
              "pm.test('D2: current_time je validny ISO 8601', function(){ if(body.current_time){ pm.expect(new Date(body.current_time).toString()).to.not.eql('Invalid Date'); } });"
            ]
          }
        }
      ],
