    {
      "name": "[FUNC+DATA] Widget Config - obsah a formaty",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var body = pm.response.json();",
              "pm.test('F1: webchatURL je validna HTTPS URL', function(){ pm.expect(body.webchatURL).to.match(/^https:\\/\\/.+/); });",
              "pm.test('F2: userData obsahuje alcs_ChatBot', function(){ pm.expect(body.userData).to.be.an('object'); pm.expect(body.userData).to.have.property('alcs_ChatBot'); });",
              "pm.test('F3: statisticURL1 existuje', function(){ pm.expect(body).to.have.property('statisticURL1'); });",
              "pm.test('D1: statisticTimeout1 je kladne cislo', function(){ if(body.statisticTimeout1){ pm.expect(body.statisticTimeout1).to.be.a('number').and.above(0); } });",
              "pm.test('D2: alcs_ChatBot je string true alebo false', function(){ var v = body.userData && body.userData.alcs_ChatBot; if(v !== undefined){ pm.expect(['true','false']).to.include(String(v)); } });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "*/*"
          }
        ],
        "url": {
