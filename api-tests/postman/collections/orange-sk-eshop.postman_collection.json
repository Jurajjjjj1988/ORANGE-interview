    {
      "name": "[NEG] Neexistujuci service ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('N1: API necrashne - ziadny 500', function(){ pm.response.to.not.have.status(500); });",
              "pm.test('N2: Odpoveda s ocakavanym HTTP kodom', function(){ pm.expect([200,400,404,422]).to.include(pm.response.code); });",
              "pm.test('N3: status=false ALEBO pole chyba (KNOWN DEFECT CB24-001)', function(){",
              "  if(pm.response.code === 200){",
              "    try {",
              "      var body = pm.response.json();",
              "      if(body.status === undefined){ console.warn('DEFECT CB24-001: status pole chyba'); pm.expect(true).to.be.true; }",
              "      else { pm.expect(body.status).to.eql(false); }",
              "    } catch(e){ pm.expect(true).to.be.true; }",
              "  }",
              "});",
              "pm.test('N4: Odpoved neobsahuje Orange data', function(){",
              "  var expectedCompany = pm.environment.get('expected_company_name');",
              "  if(pm.response.code===200){ try{ pm.expect(pm.response.json().company_name).to.not.eql(expectedCompany); }catch(e){ pm.expect(true).to.be.true; } }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "*/*"
          },
          {
            "key": "Origin",
            "value": "{{base_url}}"
          }
        ],
        "url": {
          "raw": "{{callback24_url}}/api/browser/service_status/NEEXISTUJUCI-SERVICE-999/EN",
